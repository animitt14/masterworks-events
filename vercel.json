{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "includeFiles": "{generate_rsvp.py,*.json}" }
    },
    {
      "src": "api/action.py",
      "use": "@vercel/python"
    },
    {
      "src": "docs/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/action", "dest": "/api/action.py" },
    { "src": "/(process|personas|contacts)\\.html", "dest": "/docs/$1.html" },
    { "src": "/.*", "dest": "/api/index.py" }
  ]
}
